layout {
  default_tab_template {
    children
    pane size=1 borderless=true {
      plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
        format_left   "{mode}#[bg=#eff1f5] {tabs}"
        format_right  "#[bg=#eff1f5] {command_date}{command_time}"
        format_space  "#[bg=#eff1f5]"

        mode_normal   "#[bg=#1e66f5,fg=#eff1f5,bold] NORMAL "
        mode_tmux     "#[bg=#df8e1d,fg=#eff1f5,bold] TMUX "
        mode_tab      "#[bg=#40a02b,fg=#eff1f5,bold] TAB "
        mode_pane     "#[bg=#ea76cb,fg=#eff1f5,bold] PANE "
        mode_scroll   "#[bg=#8839ef,fg=#eff1f5,bold] SCROLL "
        mode_session  "#[bg=#fe640b,fg=#eff1f5,bold] SESSION "
        mode_move     "#[bg=#04a5e5,fg=#eff1f5,bold] MOVE "
        mode_resize   "#[bg=#179299,fg=#eff1f5,bold] RESIZE "
        mode_locked   "#[bg=#d20f39,fg=#eff1f5,bold] LOCKED "
        mode_search   "#[bg=#8839ef,fg=#eff1f5,bold] SEARCH "
        mode_rename_tab  "#[bg=#40a02b,fg=#eff1f5,bold] RENAME TAB "
        mode_rename_pane "#[bg=#ea76cb,fg=#eff1f5,bold] RENAME PANE "

        tab_normal               "#[fg=#9ca0b0,bg=#eff1f5] {name} "
        tab_normal_fullscreen    "#[fg=#9ca0b0,bg=#eff1f5] {name} "
        tab_active               "#[fg=#4c4f69,bg=#eff1f5,bold] {name} "
        tab_active_fullscreen    "#[fg=#df8e1d,bg=#eff1f5,bold] «{name}» "
        tab_sync_indicator       "  "
        tab_floating_indicator   "󰉈 "

        command_date_command  "date '+%a %d %b'"
        command_date_format   "#[fg=#eff1f5,bg=#ea76cb,bold] {stdout} "
        command_date_interval "30"

        command_time_command  "date '+%H:%M'"
        command_time_format   "#[fg=#eff1f5,bg=#179299,bold] {stdout} "
        command_time_interval "10"
      }
    }
  }

  tab name="dotfiles" cwd="/home/alh/Code/dotfiles/" {
    pane split_direction="vertical" {
      pane command="nvim"
      pane command="bash" { args "-lc" "claude"; }
    }
  }

  tab name="btop" cwd="/tmp" {
      pane command="btop"
  }
}
