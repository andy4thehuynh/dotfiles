// Catppuccin Mocha theme for Zellij.
// Hex values sourced from config/kitty/themes/mocha.conf + config/btop/themes/catppuccin_mocha.theme.

themes {
    catppuccin-mocha {
        fg      "#cdd6f4"
        bg      "#1e1e2e"
        black   "#45475a"
        red     "#f38ba8"
        green   "#a6e3a1"
        yellow  "#f9e2af"
        blue    "#89b4fa"
        magenta "#f5c2e7"
        cyan    "#94e2d5"
        white   "#bac2de"
        orange  "#fab387"
    }
}
