[color]
  ui = true
[core]
  editor = nvim -c 'startinsert'
  excludesfile = ~/.gitignore_global
  pager = delta
[pager]
  diff = bat --language=diff --paging=always
[user]
  email = 2831414+andy4thehuynh@users.noreply.github.com
  name = Andy Huynh
[github]
  user = andy4thehuynh
[alias]
  rbc = rebase --continue
  pb = "!git push origin \"$(git rev-parse --abbrev-ref HEAD)\""
  pbf = "!git push -f origin \"$(git rev-parse --abbrev-ref HEAD)\""
  up = "!git pull origin \"$(git rev-parse --abbrev-ref HEAD)\""
  lg = log --graph --pretty=format:'%Cred%h%Creset %C(yellow)%an%d%Creset %s %Cgreen(%cr)%Creset' --date=relative
[init]
  defaultBranch = main
[pull]
  rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true  # use n and N to move between diff sections
[merge]
  conflictStyle = zdiff3
